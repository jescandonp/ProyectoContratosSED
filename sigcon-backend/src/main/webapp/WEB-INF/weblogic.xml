<?xml version="1.0" encoding="UTF-8"?>
<weblogic-web-app
    xmlns="http://xmlns.oracle.com/weblogic/weblogic-web-app"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://xmlns.oracle.com/weblogic/weblogic-web-app
        http://xmlns.oracle.com/weblogic/weblogic-web-app/1.9/weblogic-web-app.xsd">

    <weblogic-version>12.2.1</weblogic-version>

    <container-descriptor>
        <!--
            Forzar uso de las librerias Spring empaquetadas en el WAR,
            no las versiones propias de WebLogic (evita conflictos de version).

            IMPORTANTE (WebLogic 12.2.1): prefer-web-inf-classes=true es
            MUTUAMENTE EXCLUYENTE con prefer-application-packages y
            prefer-application-resources. No se pueden usar simultaneamente.
            Se usa prefer-web-inf-classes porque cubre todos los paquetes
            del WAR de forma global, que es lo requerido para Spring Boot.
        -->
        <prefer-web-inf-classes>true</prefer-web-inf-classes>
    </container-descriptor>

    <context-root>/sigcon</context-root>
</weblogic-web-app>
